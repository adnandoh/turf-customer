# ================================================
# TURF BOOKING SYSTEM - CUSTOMER FRONTEND (.env)
# ================================================

# Application Info
VITE_APP_NAME=TurfBook
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Sports Turf Booking System - Customer Portal

# API Configuration
VITE_API_BASE_URL=https://turf-backend-production.up.railway.app
VITE_API_TIMEOUT=10000

# Backend API Endpoints
VITE_CRICKET_API_URL=https://turf-backend-production.up.railway.app/api/cricket
VITE_PICKLEBALL_API_URL=https://turf-backend-production.up.railway.app/api/pickleball
VITE_BOOKING_API_URL=https://turf-backend-production.up.railway.app/api
VITE_AUTH_API_URL=https://turf-backend-production.up.railway.app/api-token-auth

# Development Settings
VITE_NODE_ENV=development
VITE_PORT=5173
VITE_HOST=localhost

# Debug Settings
VITE_DEBUG=true
VITE_LOG_LEVEL=info

# Feature Flags
VITE_ENABLE_CRICKET=true
VITE_ENABLE_PICKLEBALL=true
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_ANALYTICS=false

# UI/UX Settings
VITE_DEFAULT_THEME=light
VITE_ENABLE_DARK_MODE=true
VITE_DEFAULT_LANGUAGE=en
VITE_CURRENCY=INR
VITE_CURRENCY_SYMBOL=₹

# Booking Configuration
VITE_MIN_BOOKING_DURATION=60
VITE_MAX_ADVANCE_BOOKING_DAYS=30
VITE_BOOKING_TIME_SLOTS=60
VITE_DEFAULT_SPORT=cricket

# Contact Information
VITE_CONTACT_PHONE=+91-9876543210
VITE_CONTACT_EMAIL=info@turfbooking.com
VITE_CONTACT_ADDRESS=123 Sports Complex, City, State 12345

# Social Media Links
VITE_FACEBOOK_URL=https://facebook.com/turfbooking
VITE_INSTAGRAM_URL=https://instagram.com/turfbooking
VITE_TWITTER_URL=https://twitter.com/turfbooking

# Google Services (Optional)
VITE_GOOGLE_MAPS_API_KEY=
VITE_GOOGLE_ANALYTICS_ID=
VITE_GOOGLE_TAG_MANAGER_ID=

# Payment Gateway (Future use)
VITE_RAZORPAY_KEY_ID=
VITE_STRIPE_PUBLISHABLE_KEY=
VITE_PAYPAL_CLIENT_ID=

# Notification Services
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=

# Error Tracking
VITE_SENTRY_DSN=
VITE_BUGSNAG_API_KEY=

# Performance Monitoring
VITE_ENABLE_PERFORMANCE_MONITORING=false
VITE_PERFORMANCE_SAMPLE_RATE=0.1

# SEO Settings
VITE_SITE_URL=https://turf-customer.vercel.app
VITE_SITE_TITLE=TurfBook - Sports Turf Booking
VITE_SITE_DESCRIPTION=Book cricket and pickleball courts online. Easy booking, instant confirmation.
VITE_SITE_KEYWORDS=turf booking, cricket court, pickleball court, sports booking

# PWA Settings
VITE_PWA_NAME=TurfBook
VITE_PWA_SHORT_NAME=TurfBook
VITE_PWA_THEME_COLOR=#1976d2
VITE_PWA_BACKGROUND_COLOR=#ffffff

# Build Settings
VITE_BUILD_ANALYZE=false
VITE_BUILD_SOURCEMAP=true
VITE_BUILD_MINIFY=true

# CDN Settings (Production)
VITE_CDN_URL=
VITE_ASSETS_CDN_URL=

# Security Settings
VITE_ENABLE_CSP=false
VITE_CSP_REPORT_URI=

# Maintenance Mode
VITE_MAINTENANCE_MODE=false
VITE_MAINTENANCE_MESSAGE=We are currently under maintenance. Please check back later.

# Regional Settings
VITE_TIMEZONE=Asia/Kolkata
VITE_DATE_FORMAT=DD/MM/YYYY
VITE_TIME_FORMAT=HH:mm

# Booking Pricing (Display purposes - actual pricing from backend)
VITE_CRICKET_MORNING_PRICE=1200
VITE_CRICKET_EVENING_PRICE=2000
VITE_PICKLEBALL_MORNING_PRICE=800
VITE_PICKLEBALL_EVENING_PRICE=1200